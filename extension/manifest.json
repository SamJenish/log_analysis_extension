{
  "manifest_version": 3,
  "name": "Log Failure Analyzer",
  "version": "1.0.0",
  "description": "Analyze deployment logs from your browser and get actionable failure diagnostics.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Log Failure Analyzer"
  },
  "permissions": ["activeTab"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-analysis.js", "content-script.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
